# 1753 SKINCARE – Environment Variables
# Kopiera till .env och fyll i dina värden. COMMITTA ALDRIG .env!

# ---- Server ----
BACKEND_PORT=3001
JWT_SECRET=byt-till-en-lang-hemlig-nyckel

# ---- Databas (Railway injicerar automatiskt) ----
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ---- OpenAI (Hudanalys + Chatt) ----
OPENAI_API_KEY=sk-...

# ---- Fortnox (Bokföring) ----
FORTNOX_CLIENT_ID=
FORTNOX_CLIENT_SECRET=
FORTNOX_ACCESS_TOKEN=
FORTNOX_REFRESH_TOKEN=

# ---- Ongoing WMS (3PL Lager) ----
# Base URL: https://api.ongoingwarehouse.com/{goodsOwnerId}
ONGOING_BASE_URL=
ONGOING_GOODS_OWNER_ID=
ONGOING_USERNAME=
ONGOING_PASSWORD=

# ---- Viva Wallet (Betalning) ----
VIVA_CLIENT_ID=
VIVA_CLIENT_SECRET=
VIVA_SOURCE_CODE=
# "demo" eller "production"
VIVA_ENVIRONMENT=demo
# Webhook-verifieringsnyckel (från Viva dashboard)
VIVA_VERIFICATION_KEY=
# Publik butiks-URL (Next.js) – används för omdirigering från gamla payment-*.html på API-hosten
FRONTEND_URL=https://www.1753skin.com

# ---- E-post (Resend) ----
# Krävs för orderbekräftelse m.m. Verifiera domän + avsändaradress i Resend-dashboarden.
RESEND_API_KEY=re_...
EMAIL_FROM=christopher@1753skincare.com
# Base-URL for unsubscribe-lankar i e-post
BASE_URL=https://api.1753skin.com

# ---- Valyu (Webbsökning för nyhetsbrev) ----
# $10 gratis-kredit vid start. Används av scripts/generate-newsletter.js
VALYU_API_KEY=val-...

# ---- Admin-åtkomst ----
# Skyddar Fortnox/Ongoing proxy-routes; skickas som x-admin-key header
ADMIN_API_KEY=
