# 1753 SKINCARE – Environment Variables
# Kopiera till .env och fyll i dina värden. COMMITTA ALDRIG .env!

# ---- OpenAI (Hudanalys) ----
OPENAI_API_KEY=sk-...

# ---- Fortnox (Bokföring) ----
FORTNOX_CLIENT_ID=
FORTNOX_CLIENT_SECRET=
FORTNOX_ACCESS_TOKEN=
FORTNOX_REFRESH_TOKEN=

# ---- Ongoing WMS (3PL Lager) ----
# Base URL: https://api.ongoingwarehouse.com/{goodsOwnerId}
ONGOING_BASE_URL=
ONGOING_GOODS_OWNER_ID=
ONGOING_USERNAME=
ONGOING_PASSWORD=

# ---- Viva Wallet (Betalning) ----
VIVA_MERCHANT_ID=
VIVA_API_KEY=
VIVA_CLIENT_ID=
VIVA_CLIENT_SECRET=
VIVA_SOURCE_CODE=
# "demo" eller "production"
VIVA_ENVIRONMENT=demo

# ---- Server ----
BACKEND_PORT=3001
