# 1753 SKINCARE – Environment Variables
# Kopiera till .env och fyll i dina värden. COMMITTA ALDRIG .env!

# ---- Server ----
BACKEND_PORT=3001
JWT_SECRET=byt-till-en-lang-hemlig-nyckel

# ---- Databas (Railway injicerar automatiskt) ----
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ---- OpenAI (Hudanalys + Chatt) ----
OPENAI_API_KEY=sk-...

# ---- Fortnox (Bokföring) ----
FORTNOX_CLIENT_ID=
FORTNOX_CLIENT_SECRET=
FORTNOX_ACCESS_TOKEN=
FORTNOX_REFRESH_TOKEN=

# ---- Ongoing WMS (3PL Lager) ----
# Base URL: https://api.ongoingwarehouse.com/{goodsOwnerId}
ONGOING_BASE_URL=
ONGOING_GOODS_OWNER_ID=
ONGOING_USERNAME=
ONGOING_PASSWORD=

# ---- Viva Wallet (Betalning) ----
VIVA_CLIENT_ID=
VIVA_CLIENT_SECRET=
VIVA_SOURCE_CODE=
# Krävs för återkommande prenumerationsdebiteringar (Transaction API, Basic Auth)
VIVA_MERCHANT_ID=
VIVA_API_KEY=
# "demo" eller "production" – MÅSTE vara "production" vid lansering
VIVA_ENVIRONMENT=demo
# Webhook-verifieringsnyckel (från Viva dashboard) – KRÄVS i produktion för säkerhet
VIVA_VERIFICATION_KEY=
# Publik butiks-URL (Next.js) – används för omdirigering från Viva efter betalning
FRONTEND_URL=https://www.1753skin.com

# ---- E-post (Resend) ----
# Krävs för orderbekräftelse m.m. Verifiera domän + avsändaradress i Resend-dashboarden.
RESEND_API_KEY=re_...
EMAIL_FROM=christopher@1753skincare.com
# Base-URL for unsubscribe-lankar i e-post
BASE_URL=https://api.1753skin.com

# ---- Frontend (Next.js) ----
# Sätts som build-time env på Railway frontend-tjänsten
NEXT_PUBLIC_API_URL=https://api.1753skin.com/api

# ---- Valyu (Webbsökning för nyhetsbrev) ----
# $10 gratis-kredit vid start. Används av scripts/generate-newsletter.js
VALYU_API_KEY=val-...

# ---- Admin-åtkomst ----
# Skyddar Fortnox/Ongoing proxy-routes + nyhetsbrev; skickas som x-admin-key header.
# VIKTIGT: Standard-fallback "1753-admin-key" – MÅSTE bytas i produktion!
ADMIN_API_KEY=
